# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Vertex AI (Gemini via GCP service account)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# 로컬: 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# 클라우드 배포 (Fly/Vercel) — 권장: base64 인코딩한 JSON. PowerShell argv 의 따옴표 이스케이프 hell 회피.
# GOOGLE_APPLICATION_CREDENTIALS_JSON_B64=<base64-encoded JSON>
# (Unix 셸에선 raw JSON 도 동작) GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Server
PORT=3000
NODE_ENV=development

# Admin dashboard (dev/QA only — 출시 빌드에서는 절대 활성화 금지)
# ADMIN_DASHBOARD_ENABLED=true 일 때만 /api/admin/* 라우트 + impersonation 경로 활성화
ADMIN_DASHBOARD_ENABLED=false
ADMIN_SECRET=

# CORS — 콤마로 구분된 허용 origin 목록. 미설정 시 cors() 전체 허용 (로컬 dev).
# 프로덕션: admin 대시보드 URL 만 화이트리스트.
# CORS_ALLOWED_ORIGINS=https://haruadmin.vercel.app
