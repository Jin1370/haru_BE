# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ElevenLabs
ELEVENLABS_API_KEY=sk_your-elevenlabs-api-key

# Server
PORT=3000
NODE_ENV=development

# Vertex AI (Gemini via GCP service account)
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# 로컬: 파일 경로
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# 클라우드 배포 (Fly/Vercel) — 권장: base64 인코딩한 JSON. PowerShell argv 의 따옴표 이스케이프 hell 회피.
# GOOGLE_APPLICATION_CREDENTIALS_JSON_B64=<base64-encoded JSON>
# (Unix 셸에선 raw JSON 도 동작) GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Open AI moderation api (message-moderation-v1 follow-up, B 안)
# 사전 차단 통과 메시지를 omni-moderation-latest 로 2차 검수 (자모 우회 / leet
# / 한자 변환 / 그루밍 / 스캠). 호출 자체 무료. 미설정 시 OpenAI layer skip —
# 사전 차단만 동작 (fail-open).
OPENAI_API_KEY=sk-proj-your-openai-api-key

# 프로필 사진 워터컬러 변환 (photo-watercolor-pipeline) — Azure OpenAI(APIM 프록시).
# 회사 제공 키. 3개 모두 set 되면 photoConversion 이 OpenAI 직접 대신 Azure 경유로 호출.
# 미설정 시 OPENAI_API_KEY 로 OpenAI 직접 호출 (fallback).
#   * BASE_URL 은 deployment 까지 포함 (.../deployments/<deployment-name>). 경로에 /openai 없음(APIM 매핑).
#   * 인증은 api-key 헤더 (Authorization Bearer 아님 — SDK 가 보내도 APIM 이 무시).
#   * ⚠️ 발급 키는 dev/test 전용: 총 모델 호출 500회 캡. 출시 전 prod 한도 별도 협의.
AZURE_IMAGE_BASE_URL=https://dev-perso-imagedubbing-apim.azure-api.net/perso-dubbing-image/deployments/gpt-image-2
AZURE_IMAGE_API_VERSION=2025-04-01-preview
AZURE_IMAGE_API_KEY=your-azure-apim-subscription-key

# Admin dashboard (dev/QA only — 출시 빌드에서는 절대 활성화 금지)
# ADMIN_DASHBOARD_ENABLED=true 일 때만 /api/admin/* 라우트 + impersonation 경로 활성화
ADMIN_DASHBOARD_ENABLED=false
ADMIN_SECRET=

# 디스커버 "지나친 카드 다시 보기" (pass 스와이프 리셋) 일몰 게이트.
# viewer 의 pass 스와이프 행을 일괄 삭제해 pass 했던 후보를 다시 디스커버 풀에
# 등장시키는 베타 풀-고갈 탈출구. 베타 기본 ON. 'false' 일 때만 비활성:
#   * DELETE /api/discover/passes → 403 + code:'pass_reset_disabled'
#   * GET /api/discover/quota 응답의 pass_reset_enabled 플래그 → false (FE 버튼 숨김)
# 미설정 시 활성 (기본 ON). 유저 스케일 임계 도달 시 'false' 로 일몰.
DISCOVER_PASS_RESET_ENABLED=true

# CORS — 콤마로 구분된 허용 origin 목록. 미설정 시 cors() 전체 허용 (로컬 dev).
# 프로덕션: admin 대시보드 URL 만 화이트리스트.
# CORS_ALLOWED_ORIGINS=https://haruadmin.vercel.app

# Moderation (message-moderation-v1, PR2)
# 누적 신고 수가 이 임계치에 도달하면 reported user 가 자동 freeze 됨
# (is_active=false + frozen_at=now() + freeze_events INSERT). int min=1 max=100.
# 미설정 시 default=3.
AUTO_FREEZE_REPORT_THRESHOLD=3

# 보이스 재녹음(클론 재생성) 레이트리밋 — ElevenLabs 월간 voice operations 풀 보호.
# 최초 등록은 카운트 제외, 재등록만 윈도우당 캡. 미설정 시 default 2회 / 30일.
VOICE_RECLONE_MONTHLY_CAP=2
VOICE_RECLONE_WINDOW_DAYS=30

# Email confirmation redirect (Supabase enable_confirmations=true 정합)
# signUp 시 emailRedirectTo 로 전달되며 Supabase 인증 메일 링크 destination 이 됨.
# Supabase Dashboard 의 Redirect URLs allow-list 에 동일 URL 등록 필수.
# 미설정 시 기본값 http://localhost:3000/auth/callback (로컬 dev 만 의미).
EMAIL_CONFIRM_REDIRECT_URL=https://haruvoice.com/auth/callback
